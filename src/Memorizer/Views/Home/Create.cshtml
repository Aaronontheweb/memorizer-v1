@{
    ViewData["Title"] = "Create Memory";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0">
                    <i class="fas fa-plus me-2"></i>
                    Create New Memory
                </h4>
            </div>
            <div class="card-body">
                <form id="createMemoryForm">
                    <div class="mb-3">
                        <label for="title" class="form-label">Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="title" placeholder="Title for this memory" required>
                        <div class="form-text">A descriptive title is required for organization and search</div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="type" class="form-label">Type <span class="text-danger">*</span></label>
                                <select class="form-select" id="type" required>
                                    <option value="">Select type...</option>
                                    <option value="reference">Reference Material</option>
                                    <option value="procedure">Procedure/How-to</option>
                                    <option value="preference">User Preference</option>
                                    <option value="project_note">Project Note</option>
                                    <option value="example">Example/Pattern</option>
                                    <option value="todo">Action Item</option>
                                    <option value="reflection">Reflection/Lesson</option>
                                    <option value="conversation">Conversation</option>
                                    <option value="document">Document</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="source" class="form-label">Source <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="source" placeholder="e.g., user, system, LLM, documentation" required>
                                <div class="form-text">Who or what created this memory</div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="location" class="form-label">Location</label>
                        <select class="form-select" id="location">
                            <option value="">Unfiled (no workspace/project)</option>
                        </select>
                        <div class="form-text">Assign this memory to a workspace or project</div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="content" class="form-label">Content <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="content" rows="8" placeholder="Enter the memory content (supports markdown, JSON, or plain text)" required></textarea>
                        <div class="form-text">The main content that will be vectorized and searchable</div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label for="tags" class="form-label">Tags</label>
                                <input type="text" class="form-control" id="tags" placeholder="tag1, tag2, tag3">
                                <div class="form-text">Comma-separated tags for better organization</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label for="confidence" class="form-label">Confidence</label>
                                <input type="range" class="form-range" id="confidence" min="0" max="1" step="0.1" value="1.0" oninput="updateConfidenceValue()">
                                <div class="d-flex justify-content-between">
                                    <small class="text-muted">0.0</small>
                                    <small class="text-muted" id="confidenceValue">1.0</small>
                                    <small class="text-muted">1.0</small>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-between">
                                                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">                            <i class="fas fa-arrow-left me-2"></i>                            Back to List                        </a>
                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            <i class="fas fa-save me-2"></i>
                            Create Memory
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function updateConfidenceValue() {
    const confidence = document.getElementById('confidence').value;
    document.getElementById('confidenceValue').textContent = parseFloat(confidence).toFixed(1);
}

function addTag(tagName) {
    const tagsField = document.getElementById('tags');
    const currentTags = tagsField.value.trim();
    
    // Parse existing tags
    const existingTags = currentTags.split(',').map(t => t.trim()).filter(t => t.length > 0);
    
    // Check if tag already exists - if so, remove it (toggle behavior)
    if (existingTags.includes(tagName)) {
        // Remove the tag
        const updatedTags = existingTags.filter(t => t !== tagName);
        tagsField.value = updatedTags.join(', ');
        return;
    }
    
    // Add the tag
    if (currentTags === '') {
        tagsField.value = tagName;
    } else {
        tagsField.value = currentTags + ', ' + tagName;
    }
}

document.getElementById('createMemoryForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const submitBtn = document.getElementById('submitBtn');
    const originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Creating...';
    submitBtn.disabled = true;
    
    try {
        const tags = document.getElementById('tags').value
            .split(',')
            .map(tag => tag.trim())
            .filter(tag => tag.length > 0);
        
        // Parse location selection
        const locationValue = document.getElementById('location').value;
        let workspaceId = null;
        let projectId = null;

        if (locationValue) {
            const [type, id] = locationValue.split(':');
            if (type === 'workspace') {
                workspaceId = id;
            } else if (type === 'project') {
                projectId = id;
            }
        }

        const requestData = {
            title: document.getElementById('title').value || null,
            type: document.getElementById('type').value,
            content: document.getElementById('content').value,
            source: document.getElementById('source').value,
            tags: tags.length > 0 ? tags : null,
            confidence: parseFloat(document.getElementById('confidence').value),
            workspaceId: workspaceId,
            projectId: projectId
        };
        
        const response = await fetch('/api/memory', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(requestData)
        });
        
        if (response.ok) {
            // Success - redirect to view the newly created memory
            const createdMemory = await response.json();
            window.location.href = `/view/${createdMemory.id}`;
        } else {
            const errorData = await response.json();
            throw new Error(errorData.title || 'Failed to create memory');
        }
    } catch (error) {
        console.error('Error creating memory:', error);
        alert('Error creating memory: ' + error.message);
    } finally {
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
    }
});

// Load workspace tree and populate the location dropdown
async function loadLocationOptions() {
    const locationSelect = document.getElementById('location');

    try {
        const response = await fetch('/api/workspace-tree');
        if (!response.ok) {
            console.error('Failed to load workspace tree');
            return;
        }

        const data = await response.json();

        // Build hierarchical options from workspaces
        function addWorkspaceOptions(workspaces, prefix = '') {
            for (const ws of workspaces) {
                const indent = prefix ? prefix + ' ' : '';

                // Add workspace option
                const wsOption = document.createElement('option');
                wsOption.value = `workspace:${ws.id}`;
                wsOption.textContent = indent + '📁 ' + ws.name;
                if (!prefix) wsOption.style.fontWeight = 'bold';
                locationSelect.appendChild(wsOption);

                // Add projects under this workspace
                if (ws.projects && ws.projects.length > 0) {
                    addProjectOptions(ws.projects, prefix + '──');
                }

                // Add nested workspaces
                if (ws.children && ws.children.length > 0) {
                    addWorkspaceOptions(ws.children, prefix + '──');
                }
            }
        }

        function addProjectOptions(projects, prefix) {
            for (const proj of projects) {
                const option = document.createElement('option');
                option.value = `project:${proj.id}`;
                option.textContent = prefix + ' 📋 ' + proj.name;
                locationSelect.appendChild(option);

                // Add nested projects
                if (proj.children && proj.children.length > 0) {
                    addProjectOptions(proj.children, prefix + '──');
                }
            }
        }

        if (data.workspaces) {
            addWorkspaceOptions(data.workspaces);
        }

        // Pre-select location based on query parameters
        const urlParams = new URLSearchParams(window.location.search);
        const projectId = urlParams.get('projectId');
        const workspaceId = urlParams.get('workspaceId');

        if (projectId) {
            locationSelect.value = `project:${projectId}`;
        } else if (workspaceId) {
            locationSelect.value = `workspace:${workspaceId}`;
        }
    } catch (error) {
        console.error('Error loading workspace tree:', error);
    }
}

// Load location options on page load
loadLocationOptions();

// Add some helpful example content based on type selection
document.getElementById('type').addEventListener('change', function() {
    const contentField = document.getElementById('content');
    const sourceField = document.getElementById('source');
    const type = this.value;
    
    if (contentField.value === '') {
        switch(type) {
            case 'reference':
                contentField.placeholder = 'Example: Memorizer uses PostgreSQL with pgvector extension for storing and searching vectorized memories. Key tables: memories, memory_relationships.';
                sourceField.value = 'documentation';
                break;
            case 'procedure':
                contentField.placeholder = 'Example: To update a memory: 1. Fetch existing memory, 2. Modify content, 3. Re-vectorize with embedding service, 4. Update database record.';
                sourceField.value = 'system';
                break;
            case 'preference':
                contentField.placeholder = 'Example: User prefers pagination with 20 items per page by default.';
                sourceField.value = 'user';
                break;
            case 'todo':
                contentField.placeholder = 'Example: Implement memory search filters by date range and confidence score.';
                sourceField.value = 'user';
                break;
            default:
                contentField.placeholder = 'Enter the memory content (supports markdown, JSON, or plain text)';
                sourceField.value = '';
        }
    }
});
</script>
} 